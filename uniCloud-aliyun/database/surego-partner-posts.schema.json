{
  "bsonType": "object",
  "required": ["title", "type", "creator_id", "status", "moderation_status"],
  "permission": {
    "read": true,
    "create": "auth.uid != null",
    "update": "doc.creator_id == auth.uid",
    "delete": "doc.creator_id == auth.uid"
  },
  "properties": {
    "_id": { "description": "Partner post id" },
    "title": { "bsonType": "string", "title": "Title" },
    "type": { "enum": ["time_box", "long_term", "project"], "title": "Partner post type" },
    "kind": { "bsonType": "string", "title": "Partner post kind" },
    "scene": { "bsonType": "string", "title": "Partner scene" },
    "type_label": { "bsonType": "string", "title": "Partner post type label" },
    "typeLabel": { "bsonType": "string", "title": "Partner post type label compatibility field" },
    "topic_key": { "enum": ["", "hackathon", "course", "startup"], "title": "Topic key" },
    "topic_label": { "bsonType": "string", "title": "Topic label" },
    "creator_id": { "bsonType": "string", "title": "Creator user id" },
    "creatorId": { "bsonType": "string", "title": "Creator user id compatibility field" },
    "creator": { "bsonType": "string", "title": "Creator name" },
    "author": { "bsonType": "string", "title": "Author name compatibility field" },
    "avatar": { "bsonType": "string", "title": "Creator avatar" },
    "images": { "bsonType": "array", "title": "Partner post images" },
    "image": { "bsonType": "string", "title": "Primary image compatibility field" },
    "cover": { "bsonType": "string", "title": "Cover image compatibility field" },
    "city": { "bsonType": "string", "title": "City" },
    "location": { "bsonType": "string", "title": "Location" },
    "locationRange": { "bsonType": "string", "title": "Location range compatibility field" },
    "address": { "bsonType": "string", "title": "Address" },
    "latitude": { "bsonType": "double", "title": "Latitude" },
    "longitude": { "bsonType": "double", "title": "Longitude" },
    "wechat_id": {
      "bsonType": "string",
      "title": "WeChat ID",
      "permission": { "read": "doc.creator_id == auth.uid" }
    },
    "wechat_qr": {
      "bsonType": "object",
      "title": "WeChat QR image",
      "permission": { "read": "doc.creator_id == auth.uid" }
    },
    "wechat_qr_url": {
      "bsonType": "string",
      "title": "WeChat QR image URL",
      "permission": { "read": "doc.creator_id == auth.uid" }
    },
    "schedule": { "bsonType": "string", "title": "Schedule" },
    "available": { "bsonType": "string", "title": "Available time compatibility field" },
    "connection_mode": { "bsonType": "string", "title": "Connection mode" },
    "connectionMode": { "bsonType": "string", "title": "Connection mode compatibility field" },
    "connectionRule": { "bsonType": "string", "title": "Connection rule compatibility field" },
    "description": { "bsonType": "string", "title": "Description" },
    "detail": { "bsonType": "string", "title": "Detail compatibility field" },
    "expectation": { "bsonType": "string", "title": "Expectation" },
    "wants": { "bsonType": "array", "title": "Want tags" },
    "fit_tags": { "bsonType": "array", "title": "Fit tags" },
    "fitTags": { "bsonType": "array", "title": "Fit tags compatibility field" },
    "tags": { "bsonType": "array", "title": "Display tags" },
    "actionLabel": { "bsonType": "string", "title": "Action label compatibility field" },
    "status": { "enum": ["open", "matched", "converted", "paused", "closed"], "title": "Status" },
    "moderation_status": { "enum": ["pending", "approved", "rejected", "hidden", "visible"], "title": "Moderation status" },
    "moderation_note": { "bsonType": "string", "title": "Moderation note" },
    "moderated_at": { "bsonType": "timestamp", "title": "Moderated at" },
    "moderated_by": { "bsonType": "string", "title": "Moderated by" },
    "intent_count": { "bsonType": "int", "title": "Intent count" },
    "intentCount": { "bsonType": "int", "title": "Intent count compatibility field" },
    "follow_count": { "bsonType": "int", "title": "Follow count" },
    "followCount": { "bsonType": "int", "title": "Follow count compatibility field" },
    "source_activity_id": { "bsonType": "string", "title": "Converted activity id" },
    "created_at": { "bsonType": "timestamp", "title": "Created at" },
    "createdAt": { "bsonType": "string", "title": "Created at compatibility field" },
    "updated_at": { "bsonType": "timestamp", "title": "Updated at" },
    "updatedAt": { "bsonType": "string", "title": "Updated at compatibility field" }
  }
}
