{
  "bsonType": "object",
  "required": ["user_id"],
  "permission": {
    "read": "doc.user_id == auth.uid || 'admin' in auth.role || 'operator' in auth.role",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "Profile id" },
    "user_id": { "bsonType": "string", "title": "User id" },
    "nickname": { "bsonType": "string", "title": "Nickname" },
    "avatar": { "bsonType": "string", "title": "Avatar url" },
    "avatar_file_id": { "bsonType": "string", "title": "Avatar file id" },
    "profile_completed_at": { "bsonType": "timestamp", "title": "Profile completed at" },
    "mbti": { "bsonType": "string", "title": "MBTI" },
    "bio": { "bsonType": "string", "title": "Bio" },
    "quote": { "bsonType": "string", "title": "Quote" },
    "credit": { "bsonType": "int", "title": "Credit" },
    "roles": { "bsonType": "array", "title": "Roles" },
    "role_updated_at": { "bsonType": "timestamp", "title": "Role updated at" },
    "role_updated_by": { "bsonType": "string", "title": "Role updated by" },
    "created_at": { "bsonType": "timestamp", "title": "Created at" },
    "updated_at": { "bsonType": "timestamp", "title": "Updated at" }
  }
}
