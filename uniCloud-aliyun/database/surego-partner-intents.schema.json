{
  "bsonType": "object",
  "required": ["partner_post_id", "user_id", "status", "conversation_id"],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": "auth.uid != null",
    "update": false,
    "delete": "doc.user_id == auth.uid"
  },
  "properties": {
    "_id": { "description": "Partner intent id" },
    "partner_post_id": { "bsonType": "string", "title": "Partner post id" },
    "user_id": { "bsonType": "string", "title": "Intent user id" },
    "nickname": { "bsonType": "string", "title": "User nickname" },
    "avatar": { "bsonType": "string", "title": "User avatar" },
    "message": { "bsonType": "string", "title": "Intent message" },
    "status": { "enum": ["pending", "accepted", "rejected"], "title": "Status" },
    "conversation_id": { "bsonType": "string", "title": "Conversation id" },
    "created_at": { "bsonType": "timestamp", "title": "Created at" },
    "updated_at": { "bsonType": "timestamp", "title": "Updated at" }
  }
}
