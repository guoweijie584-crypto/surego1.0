{
  "bsonType": "object",
  "required": ["title", "category", "date", "time", "location", "party_mode", "status", "creator_id"],
  "permission": {
    "read": true,
    "create": "auth.uid != null",
    "update": "doc.creator_id == auth.uid",
    "delete": "doc.creator_id == auth.uid"
  },
  "properties": {
    "_id": { "description": "Activity id" },
    "title": { "bsonType": "string", "title": "Title" },
    "category": { "bsonType": "string", "title": "Category" },
    "creator_id": { "bsonType": "string", "title": "Creator user id" },
    "organizer": { "bsonType": "string", "title": "Organizer name" },
    "cover": { "bsonType": "string", "title": "Cover image url" },
    "date": { "bsonType": "string", "title": "Activity date" },
    "time": { "bsonType": "string", "title": "Start time" },
    "end_time": { "bsonType": "string", "title": "End time" },
    "location": { "bsonType": "string", "title": "Location" },
    "address": { "bsonType": "string", "title": "Address" },
    "city": { "bsonType": "string", "title": "City name" },
    "city_code": { "bsonType": "string", "title": "City code" },
    "district": { "bsonType": "string", "title": "District" },
    "latitude": { "bsonType": "double", "title": "Latitude" },
    "longitude": { "bsonType": "double", "title": "Longitude" },
    "max_participants": { "bsonType": "int", "title": "Max participants" },
    "has_participant_limit": { "bsonType": "bool", "title": "Has participant limit" },
    "require_approval": { "bsonType": "bool", "title": "Require approval" },
    "party_mode": { "enum": ["free", "sincerity", "ticket"], "title": "Party mode" },
    "amount": { "bsonType": "double", "title": "Payment amount" },
    "description": { "bsonType": "string", "title": "Description" },
    "questions": { "bsonType": "array", "title": "Registration questions" },
    "status": { "enum": ["draft", "reviewing", "published", "recruiting", "formed", "ongoing", "finished", "cancelled"], "title": "Status" },
    "moderation_status": { "enum": ["pending", "approved", "rejected", "hidden", "visible"], "title": "Moderation status" },
    "moderation_note": { "bsonType": "string", "title": "Moderation note" },
    "moderated_at": { "bsonType": "timestamp", "title": "Moderated at" },
    "moderated_by": { "bsonType": "string", "title": "Moderated by" },
    "visibility": { "enum": ["public", "members_only"], "title": "Visibility" },
    "source": { "enum": ["direct_activity", "partner_post"], "title": "Activity source" },
    "source_partner_post_id": { "bsonType": "string", "title": "Source partner post id" },
    "source_partner_intent_ids": { "bsonType": "array", "title": "Source partner intent ids" },
    "invited_user_ids": { "bsonType": "array", "title": "Invited user ids" },
    "participant_ids": { "bsonType": "array", "title": "Participant ids" },
    "created_at": { "bsonType": "timestamp", "title": "Created at" },
    "updated_at": { "bsonType": "timestamp", "title": "Updated at" }
  }
}
