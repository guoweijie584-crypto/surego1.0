{
  "bsonType": "object",
  "required": ["activity_id", "user_id", "status"],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "Check-in id" },
    "activity_id": { "bsonType": "string", "title": "Activity id" },
    "user_id": { "bsonType": "string", "title": "User id" },
    "code": { "bsonType": "string", "title": "Check-in code" },
    "status": { "enum": ["pending", "checked", "expired"], "title": "Check-in status" },
    "checked_by": { "bsonType": "string", "title": "Checked by" },
    "source": { "enum": ["manual", "scan", "participant"], "title": "Check-in source" },
    "remark": { "bsonType": "string", "title": "Remark" },
    "created_at": { "bsonType": "timestamp", "title": "Created at" },
    "checked_at": { "bsonType": "timestamp", "title": "Checked at" }
  }
}
