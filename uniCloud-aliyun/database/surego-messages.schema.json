    "partner_post_id": { "bsonType": "string", "title": "Partner post id" },
    "conversation_id": { "bsonType": "string", "title": "Conversation id" },
    "event_key": { "bsonType": "string", "title": "Idempotent business event key" },
    "type": { "bsonType": "string", "title": "Message type" },
    "title": { "bsonType": "string", "title": "Title" },
    "content": { "bsonType": "string", "title": "Content" },
    "sender": { "bsonType": "string", "title": "Sender" },
    "read": { "bsonType": "bool", "title": "Read state" },
